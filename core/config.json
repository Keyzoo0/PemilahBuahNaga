    "fg_area_ratio": 0.04,
    "settle_timeout_seconds": 8,
    "max_consecutive_rejects": 3
  },
  "timing": {
    "forward_extra_seconds": 2,
    "backward_extra_matang_seconds": 2,
    "servo_open_angle": 51,
    "servo_close_angle": 0,
    "servo_slap_hold_ms": 500,
    "cooldown_seconds": 1,
    "max_motor_runtime_seconds": 15,
