{
  "camera": {
    "cam1_bus_key": "usb1-1-1",
    "cam2_bus_key": "usb3-3-1",
    "width": 1280,
    "height": 720,
    "fps": 30
  },
  "detect": {
    "imgsz": 480,
    "conf_threshold": 0.5,
    "conf_per_class": {
      "matang": 0.5,
      "mentah": 0.5,
      "setengah matang": 0.5
    },
    "min_box_area": 4000,
