    "reject_forward_seconds": 4,
    "servo_arm_delay_seconds": 1,
    "servo_arm_delay_1": 1,
    "servo_arm_delay_2": 1
  },
  "mapping": {
    "mentah": "servo1",
    "setengah matang": "servo2",
    "matang": "straight"
  },
  "sort_cam2": {
    "paddle_roi_1": {
      "x": 256,
      "y": 371,
      "w": 670,
      "h": 223
    },
    "paddle_roi_2": {
      "x": 98,
      "y": 30,
      "w": 847,
      "h": 399
    },
    "paddle_roi": {
      "x": 520,
      "y": 37,
      "w": 368,
      "h": 663
    },
    "track_conf": 0.3,
    "track_draw_conf": 0.3,
    "min_box_area": 3000,
    "min_travel_px": 120
  },
  "serial": {
    "port": "/dev/ttyUSB0",
    "baud": 115200,
